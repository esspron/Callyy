# Admin Panel Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ⚠️ REQUIRED FOR ADMIN ACCESS: Service Role Key
# This key bypasses RLS and gives full database access
# Get it from: Supabase Dashboard → Settings → API → service_role key
# SECURITY: Never expose this key in frontend apps or public repos
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Backend URL (Railway)
VITE_BACKEND_URL=https://callyy-production.up.railway.app
