{
  "name": "@voicory/widget",
  "version": "1.0.0",
  "description": "Voicory embeddable voice and chat widget for websites",
  "main": "dist/voicory-widget.umd.js",
  "module": "dist/voicory-widget.es.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:types",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist/types",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@daily-co/daily-js": "^0.85.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "terser": "^5.44.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0"
  },
  "keywords": [
    "voicory",
    "widget",
    "voice",
    "chat",
    "ai",
    "assistant",
    "embed"
  ],
  "author": "Voicory",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/voicory/widget"
  }
}
